    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "electron-updater": "^6.3.9",
    "i18next": "^24.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.1",
    "react-router-dom": "^7.2.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@resvg/resvg-js": "^2.6.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/uuid": "^10.0.0",
